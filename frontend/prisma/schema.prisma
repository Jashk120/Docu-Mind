generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String?       @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]
  pipelineRuns  PipelineRun[]
  projects      Project[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model PipelineRun {
  id              String   @id @default(cuid())
  userId          String
  owner           String
  repo            String
  status          String
  prUrl           String?
  contextMd       String?
  readmeMd        String?
  completedCount  Int      @default(0)
  skippedCount    Int      @default(0)
  maxFiles        Int      @default(20)
  promptTokens    Int?
  completionTokens Int?
  totalTokens     Int?
  durationMs      Int?
  createdAt       DateTime @default(now())

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  files PipelineRunFile[]

  @@index([userId, createdAt])
  @@index([owner, repo, createdAt])
}

model PipelineRunFile {
  id        String   @id @default(cuid())
  runId     String
  path      String
  status    String
  reason    String?
  charCount Int?
  createdAt DateTime @default(now())

  run PipelineRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([path])
}

model Project {
  id               String   @id @default(cuid())
  userId           String
  owner            String
  repo             String
  timestamp        DateTime
  prUrl            String?
  status           String
  fileCount        Int      @default(0)
  skippedCount     Int      @default(0)
  tokenUsage       Int      @default(0)
  durationMs       Int      @default(0)
  storagePath      String
  fileDiffsJson    String?
  confidenceJson   String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([owner, repo, timestamp])
}
